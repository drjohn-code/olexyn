# Copy this file to `.env.local` and fill in your real Supabase values.
# `.env.local` is gitignored; this `.env.example` is committed as documentation.

# Supabase project URL (Dashboard → Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=

# New-style publishable key (Dashboard → Project Settings → API Keys → Publishable key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy anon key — optional fallback if your project hasn't migrated to the
# new publishable key naming yet. Leave blank if you set PUBLISHABLE_KEY above.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
